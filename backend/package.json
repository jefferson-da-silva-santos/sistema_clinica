{
  "name": "clinicadesk-backend",
  "version": "1.0.0",
  "description": "ClinicaDesk - Backend API",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "pkg": "pkg server.js --targets node18-win-x64 --output ../src-tauri/binaries/clinicadesk-server-x86_64-pc-windows-msvc.exe --assets node_modules/sqlite3/build/Release/node_sqlite3.node"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "node_modules/sqlite3/build/Release/node_sqlite3.node"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "../src-tauri/binaries"
  }
}
